{
    "name": "Node Based Configuration Language",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#node-invocation" },
        { "include": "#property-key" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#map-key" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#function-call" },
        { "include": "#components" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.nbcl",
                    "begin": "#-",
                    "end": "-#"
                },
                {
                    "name": "comment.line.nbcl",
                    "match": "#.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.nbcl",
                    "match": "\\b(if|else|while|for|in|return|match)\\b"
                },
                {
                    "name": "keyword.declaration.nbcl",
                    "match": "\\b(fn|component|import|as|local|global|set|any)\\b"
                },
                {
                    "name": "keyword.operator.nbcl",
                    "match": "\\b(null)\\b"
                }
            ]
        },
        "types": {
            "name": "support.type.nbcl",
            "match": "\\b(String|Int|Float|Bool|List|Map|Node|Lambda|Any)\\b"
        },
        "booleans": {
            "name": "constant.language.nbcl",
            "match": "\\b(true|false)\\b"
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.nbcl",
                    "match": "-?\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.nbcl",
                    "match": "-?\\b\\d+\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.nbcl",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.nbcl",
                            "match": "\\\\([ntr\\\\\"'u]|u[0-9a-fA-F]{4})"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.nbcl",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.nbcl",
                            "match": "\\\\([ntr\\\\\"'u]|u[0-9a-fA-F]{4})"
                        }
                    ]
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.nbcl",
                    "match": "=>"
                },
                {
                    "name": "keyword.operator.logical.nbcl",
                    "match": "(\\|\\||&&|!)"
                },
                {
                    "name": "keyword.operator.comparison.nbcl",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.arithmetic.nbcl",
                    "match": "(\\+|-|\\*|/|%)"
                },
                {
                    "name": "keyword.operator.range.nbcl",
                    "match": "(\\.\\.|\\.\\.=)"
                },
                {
                    "name": "keyword.operator.accessor.nbcl",
                    "match": "(\\?\\.|\\.)"
                },
                {
                    "name": "keyword.operator.accessor.nbcl",
                    "match": "(\\?\\.|(?<!=)\\.(?!=))"
                },
                {
                    "name": "keyword.operator.lambda.nbcl",
                    "match": "(?<!\\|)\\|(?!\\|)"
                }
            ]
        },
        "functions": {
            "match": "\\b(fn)\\s+([a-z][a-zA-Z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.declaration.nbcl" },
                "2": { "name": "entity.name.function.nbcl" }
            }
        },
        "function-call": {
            "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
            "captures": {
                "1": { "name": "entity.name.function.nbcl" }
            }
        },
        "property-key": {
            "match": "^\\s*([a-z_][a-zA-Z0-9_]*)\\s*(?==)",
            "captures": {
                "1": { "name": "support.type.property-name.nbcl" }
            }
        },
        "map-key": {
            "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=:)",
            "captures": {
                "1": { "name": "support.type.property-name.nbcl" }
            }
        },
        "components": {
            "match": "\\b(component)\\s+([A-Z][a-zA-Z0-9]*)\\b",
            "captures": {
                "1": { "name": "keyword.declaration.nbcl" },
                "2": { "name": "entity.name.type.nbcl" }
            }
        },
        "node-invocation": {
            "match": "\\b([A-Z][a-zA-Z0-9]*)\\b",
            "name": "entity.name.tag.nbcl"
        }
    },
    "scopeName": "source.nbl"
}